# Langfuse keys. Defaults match docker-compose's LANGFUSE_INIT_* bootstrap.
# Langfuse will create org "rag-exp", project "rag-exp", and these keys
# automatically on its first boot (postgres volume empty). Change to your
# own strong values for any non-local deployment.
LANGFUSE_PUBLIC_KEY=pk-lf-rag-exp-local
LANGFUSE_SECRET_KEY=sk-lf-rag-exp-local

# Langfuse admin login (created on first boot).
# email:    admin@rag-exp.local
# password: changeme123

# GPU device IDs per service. Defaults to 0 for all three so a single-GPU host
# Just Works. On a multi-GPU host, set these to different cards to avoid
# contention (Ollama is the biggest, ~15 GB; PaddleOCR-VL ~10 GB; API ~2 GB).
OLLAMA_GPU=0
PADDLEOCR_GPU=0
APP_GPU=0

# Override defaults if you like.
LLM_MODEL=qwen2.5:7b-instruct
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

TOP_K=12
RERANK_TOP_N=5

CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# OCR_MIN_CHARS_PER_PAGE: pages with less embedded text than this are sent
# through PaddleOCR-VL. Set very high (999999) to force OCR everywhere.
OCR_MIN_CHARS_PER_PAGE=40
